# Copy to /etc/summariezer/summariezer.env on the server and chmod 600.

# Telegram reader account app credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Source chat to read. Examples: @public_chat, https://t.me/public_chat, or an id.
SUMMARIEZER_SOURCE=hft_chat
SUMMARIEZER_CHAT=

# Authorized Telethon session path on the server.
SUMMARIEZER_SESSION=/opt/summariezer/secrets/tg-reader

# Digest behavior.
SUMMARIEZER_PROFILE=hft
SUMMARIEZER_WINDOW_DAYS=3
SUMMARIEZER_CONFIG=/opt/summariezer/app/configs/example.toml

# Delivery mode. Use Bot API for the main account DM.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DELIVERY_CHAT_ID=

# Optional user-session delivery fallback.
TELEGRAM_DELIVERY_PEER=
