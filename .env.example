# Telegram reader account app credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional delivery bot created via @BotFather.
TELEGRAM_BOT_TOKEN=

# Target chat/user/channel id for digest delivery.
# For a private DM, write to the bot first, then get the chat id.
TELEGRAM_DELIVERY_CHAT_ID=

# Optional fallback when delivering from the Telegram reader user session.
TELEGRAM_DELIVERY_PEER=
